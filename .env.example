# LeozOps AI — environment configuration
# Copy this file to ".env" and adjust as needed.

# Which knexfile environment to use: development | test | production
NODE_ENV=development

# HTTP port for the CRUD API server
PORT=3000

# ----------------------------------------------------------------------------
# Auth (Milestone #7). The server signs/verifies per-client bearer tokens with
# AUTH_SECRET and grants cross-tenant access to callers presenting ADMIN_API_KEY.
# In production AUTH_SECRET is REQUIRED (the app refuses to start without it);
# outside production a clearly-insecure dev fallback is used if unset.
# ----------------------------------------------------------------------------
# AUTH_SECRET=change-me-to-a-long-random-string
# ADMIN_API_KEY=change-me-admin-key

# ----------------------------------------------------------------------------
# Email publishing (Milestone #8A, Resend). Sending is explicitly invoked via
# POST /integrations/email/send; it is disabled (503 not_configured) until BOTH
# RESEND_API_KEY and a valid EMAIL_FROM are set. Use a Resend sandbox/test key
# for non-production.
# ----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=LeozOps <noreply@example.com>   # REQUIRED for live sending (validated)
# EMAIL_ALLOWED_FROM=                        # comma-separated exact senders a caller
#                                            # may pass as `from`; empty = reject any
#                                            # caller-provided `from` (use EMAIL_FROM only)
# Spend guardrails (per tenant/client_id) — each PROVIDER ATTEMPT (incl. retries)
# consumes one daily + rate unit, and each failed attempt counts toward the circuit:
# EMAIL_DAILY_CAP=100            # max provider attempts per client per UTC day
# EMAIL_RATE_PER_MINUTE=10       # max provider attempts per client per rolling 60s
# EMAIL_FAILURE_THRESHOLD=5      # consecutive failed attempts before circuit opens
# EMAIL_TIMEOUT_MS=10000         # per-attempt provider timeout
# EMAIL_MAX_RETRIES=2            # extra attempts after the first; clamped to a hard ceiling of 5
# EMAIL_BACKOFF_MS=250           # base backoff; retry i waits min(BACKOFF_MAX, base * 2^i)
# EMAIL_BACKOFF_MAX_MS=30000     # hard cap on a single backoff wait

# ----------------------------------------------------------------------------
# Development (default): zero-setup SQLite file. No database server required.
# ----------------------------------------------------------------------------
SQLITE_FILE=./data/leozops.dev.sqlite

# ----------------------------------------------------------------------------
# Production: PostgreSQL. Used only when NODE_ENV=production.
# Either provide a full connection string...
# DATABASE_URL=postgres://user:password@localhost:5432/leozops
# ...or the individual parts below.
PGHOST=localhost
PGPORT=5432
PGUSER=leozops
PGPASSWORD=leozops
PGDATABASE=leozops
