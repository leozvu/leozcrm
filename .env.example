# LeozOps AI — environment configuration
# Copy this file to ".env" and adjust as needed.

# Which knexfile environment to use: development | test | production
NODE_ENV=development

# HTTP port for the CRUD API server
PORT=3000

# ----------------------------------------------------------------------------
# Auth (Milestone #7). The server signs/verifies per-client bearer tokens with
# AUTH_SECRET and grants cross-tenant access to callers presenting ADMIN_API_KEY.
# In production AUTH_SECRET is REQUIRED (the app refuses to start without it);
# outside production a clearly-insecure dev fallback is used if unset.
# ----------------------------------------------------------------------------
# AUTH_SECRET=change-me-to-a-long-random-string
# ADMIN_API_KEY=change-me-admin-key

# ----------------------------------------------------------------------------
# Email publishing (Milestone #8A, Resend). Sending is explicitly invoked via
# POST /integrations/email/send; it is disabled (503 not_configured) until
# RESEND_API_KEY is set. Use a Resend sandbox/test key for non-production.
# ----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=LeozOps <noreply@example.com>
# Spend guardrails (per tenant/client_id):
# EMAIL_DAILY_CAP=100            # max sends per client per UTC day
# EMAIL_RATE_PER_MINUTE=10       # max sends per client per rolling 60s
# EMAIL_FAILURE_THRESHOLD=5      # consecutive provider failures before circuit opens
# EMAIL_TIMEOUT_MS=10000         # per-attempt provider timeout
# EMAIL_MAX_RETRIES=2            # extra attempts after the first (exponential backoff)
# EMAIL_BACKOFF_MS=250           # base backoff; attempt N waits base * 2^(N-1)

# ----------------------------------------------------------------------------
# Development (default): zero-setup SQLite file. No database server required.
# ----------------------------------------------------------------------------
SQLITE_FILE=./data/leozops.dev.sqlite

# ----------------------------------------------------------------------------
# Production: PostgreSQL. Used only when NODE_ENV=production.
# Either provide a full connection string...
# DATABASE_URL=postgres://user:password@localhost:5432/leozops
# ...or the individual parts below.
PGHOST=localhost
PGPORT=5432
PGUSER=leozops
PGPASSWORD=leozops
PGDATABASE=leozops
